{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/en", "permanent": false },
    { "source": "/ja/legal", "destination": "/en/legal", "permanent": false },
    { "source": "/ko/legal", "destination": "/en/legal", "permanent": false }
  ],
  "rewrites": [
    { "source": "/cms-assets/:path*", "destination": "/api/cms-asset?path=:path*" },
    { "source": "/:lang(en|ar|ja|ko)/services/:slug(procurement|engineering|ai-solutions|cybersecurity)", "destination": "/:lang/services/provide-spare-parts.html" },
    { "source": "/:lang(en|ar|ja|ko)/services/:slug(procurement|engineering|ai-solutions|cybersecurity).html", "destination": "/:lang/services/provide-spare-parts.html" }
  ],
  "headers": [
    {
      "source": "/api/v1/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
